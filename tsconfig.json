{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "react",
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "astro.config.mjs"],
  "exclude": [
    "node_modules",
    "dist",
    "backend",
    "backend-storefront",
    "Desktop"
  ]
}
