---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { useTranslations } from "../data/i18n";
import { products } from "../data/products";

const locale = "en";
const t = useTranslations(locale);

const cards = products.filter((p) => p.category === "pokemon-cards");
---

<BaseLayout locale={locale} title={t.nav.pokemon_cards}>
  <section class="page-hero" aria-label={t.nav.pokemon_cards}>
    <div class="bg">
      <img
        src="https://images.unsplash.com/photo-1613771404784-3a5686aa2be3?w=1920&q=80"
        alt=""
        loading="lazy"
      />
      <div class="overlay" aria-hidden="true"></div>
    </div>
    <div class="container">
      <h1>{t.nav.pokemon_cards}</h1>
      <p>{t.cat.pokemon_cards_desc}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="product-grid">
        {cards.map((p) => (
          <ProductCard
            id={p.id}
            name={p.name}
            price={p.price}
            image={p.image}
            badge={p.badge}
            grade={p.grade}
            stock={p.stock}
            locale={locale}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initProductCards, initProductPopup } from "../scripts/cart";
  initProductCards();
  initProductPopup();
</script>
