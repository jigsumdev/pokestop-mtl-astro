---
/*
  index.astro — PokéStop MTL Home Page (English)
  Design: Dark vault hero, trust bar, featured cards, mystery packs, new arrivals
*/
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { useTranslations } from "../data/i18n";
import { products, mysteryPacks } from "../data/products";

const locale = "en";
const t = useTranslations(locale);

const featuredProducts = products.filter((p) => p.badge).slice(0, 8);
const newArrivals = products.filter((p) => p.badge === "new").slice(0, 4);
---

<BaseLayout locale={locale}>
  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <h1>
            {t.hero.headline}<br />
            <span class="accent">& Collectibles</span>
          </h1>
          <p class="hero-desc">{t.hero.desc}</p>
          <div class="hero-btns">
            <a href="/shop/" class="btn-primary">
              {t.hero.cta}
              <svg class="arrow-right" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/mystery-packs/" class="btn-outline">{t.hero.cta2}</a>
          </div>
        </div>
        <div class="hero-image" aria-hidden="true">
          <img
            src="https://images.unsplash.com/photo-1613771404784-3a5686aa2be3?w=800&q=80"
            alt="PokéStop MTL — Trading Cards & Collectibles"
            width="800"
            height="600"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="trust-bar" aria-label="Why shop with us">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>{t.trust.authenticated}</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span>{t.trust.graded}</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <span>{t.trust.secure}</span>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span>{t.trust.quality}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Cards -->
  <section class="section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 id="featured-title">{t.featured.title}</h2>
          <p>{t.featured.subtitle}</p>
        </div>
        <a href="/shop/" class="view-all">
          {t.featured.view_all}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <div class="product-grid" id="featured-products">
        {featuredProducts.map((p) => (
          <ProductCard
            id={p.id}
            name={p.name}
            price={p.price}
            image={p.image}
            category={p.category}
            badge={p.badge}
            grade={p.grade}
            stock={p.stock}
            locale={locale}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Mystery Packs -->
  <section class="section mystery-section" id="mystery-packs" aria-labelledby="mystery-title">
    <div class="container">
      <div class="section-header section-header-center">
        <h2 id="mystery-title">{t.mystery.title}</h2>
        <p>{t.mystery.subtitle}</p>
        <div class="mystery-divider" aria-hidden="true"></div>
      </div>
      {mysteryPacks.length === 0 ? (
        <p style="text-align:center;color:rgba(255,255,255,0.5);padding:2rem 0">
          No mystery packs at the moment. Check back soon!
        </p>
      ) : (
        <div class="mystery-grid">
          {mysteryPacks.map((p) => (
            <div class="mystery-card">
              <div class="img-wrap">
                <img src={p.image} alt={p.name} loading="lazy" />
              </div>
              <div class="info">
                <h3>{p.name}</h3>
                <p>{p.nameFr}</p>
                <span class="price">${p.price.toFixed(2)}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- New Arrivals -->
  <section class="section section-alt" aria-labelledby="arrivals-title">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 id="arrivals-title">{t.new_arrivals.title}</h2>
          <p>{t.new_arrivals.subtitle}</p>
        </div>
        <a href="/shop/" class="view-all">
          {t.featured.view_all}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <div class="product-grid">
        {newArrivals.map((p) => (
          <ProductCard
            id={p.id}
            name={p.name}
            price={p.price}
            image={p.image}
            category={p.category}
            badge={p.badge}
            grade={p.grade}
            stock={p.stock}
            locale={locale}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initProductCards, initProductPopup } from "../scripts/cart";
  initProductCards();
  initProductPopup();
</script>
