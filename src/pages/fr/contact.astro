---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../data/i18n";

const locale = "fr";
const t = useTranslations(locale);

const iconPaths: Record<string, string> = {
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
  "map-pin": '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
};
---

<BaseLayout locale={locale} title={t.contact.title}>
  <div class="container" style="padding-top:6rem;padding-bottom:5rem;max-width:64rem">
    <div style="text-align:center;margin-bottom:3rem">
      <h1 style="font-family:var(--font-display);font-size:2.5rem;font-weight:800;margin:0 0 0.75rem">{t.contact.title}</h1>
      <p style="color:var(--text-soft);font-size:1.125rem;margin:0">{t.contact.subtitle}</p>
    </div>
    <div class="contact-grid">
      <div class="vault-card form-card">
        <form id="contact-form-fr" novalidate>
          <div class="form-row">
            <div>
              <label for="contact-name-fr">{t.contact.name}</label>
              <input type="text" id="contact-name-fr" name="name" required autocomplete="name" />
            </div>
            <div>
              <label for="contact-email-fr">{t.contact.email}</label>
              <input type="email" id="contact-email-fr" name="email" required autocomplete="email" />
            </div>
          </div>
          <div>
            <label for="contact-subject-fr">{t.contact.subject}</label>
            <input type="text" id="contact-subject-fr" name="subject" required />
          </div>
          <div>
            <label for="contact-message-fr">{t.contact.message}</label>
            <textarea id="contact-message-fr" name="message" required rows={6}></textarea>
          </div>
          <button type="submit" class="btn-primary">{t.contact.send}</button>
        </form>
      </div>
      <div>
        {t.contact.info.map((info) => (
          <div class="contact-info-card">
            <div class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" set:html={iconPaths[info.icon] ?? ""} />
            </div>
            <div>
              <h4>{info.label}</h4>
              <p>{info.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form-fr') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const toast = document.getElementById('newsletter-toast');
    const toastText = document.getElementById('newsletter-toast-text');
    if (toast && toastText) {
      toastText.textContent = 'Message envoyé! Nous vous répondrons sous peu.';
      toast.classList.remove('toast-error');
      toast.classList.add('show');
      clearTimeout((window as any)._toastTimeout);
      (window as any)._toastTimeout = setTimeout(() => toast.classList.remove('show'), 3500);
    }
    form.reset();
  });
</script>
