---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../data/i18n";

const locale = "fr";
const t = useTranslations(locale);

const valueIcons: Record<string, string> = {
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  star: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
  heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
  truck: '<rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>',
};
---

<BaseLayout locale={locale} title={t.about.title}>
  <section class="page-hero" aria-label={t.about.title}>
    <div class="bg">
      <img src="https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1920&q=80" alt="" loading="lazy" />
      <div class="overlay" aria-hidden="true"></div>
    </div>
    <div class="container">
      <h1>{t.about.title}</h1>
      <p>{t.about.subtitle}</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:56rem">
      <div class="about-story-grid">
        <div>
          <h2 style="color:var(--accent);margin-bottom:1rem;font-family:var(--font-display);font-size:1.75rem;font-weight:700">{t.about.story_title}</h2>
          <p style="color:var(--text-dark);line-height:1.7">{t.about.story}</p>
        </div>
        <div>
          <h2 style="color:var(--accent);margin-bottom:1rem;font-family:var(--font-display);font-size:1.75rem;font-weight:700">{t.about.mission_title}</h2>
          <p style="color:var(--text-dark);line-height:1.7">{t.about.mission}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt" aria-labelledby="values-title-fr">
    <div class="container">
      <h2 id="values-title-fr" style="text-align:center;font-family:var(--font-display);font-size:2rem;font-weight:700;margin-bottom:3rem">{t.about.values_title}</h2>
      <div class="values-grid">
        {t.about.values.map((v) => (
          <div class="value-card">
            <div class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24" set:html={valueIcons[v.icon] ?? ""} />
            </div>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
