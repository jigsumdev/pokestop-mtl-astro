---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="en" title="Shipping Policy">
  <div class="container policy-page">
    <a href="/" class="link-back" style="display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1.5rem;font-size:0.875rem">← Back to Home</a>
    <h1>Shipping Policy</h1>
    <p class="policy-updated">Last updated: March 2025</p>
    <div class="policy-content">
      <h2>Shipping Rates</h2>
      <p>Free shipping on orders over $100 CAD within Canada. Standard shipping rates apply for orders under $100.</p>
      <h2>Processing Time</h2>
      <p>Orders are processed within 1–2 business days. You will receive a tracking number once your order ships.</p>
      <h2>Delivery Times</h2>
      <p>Standard shipping within Canada: 3–7 business days. Express options available at checkout.</p>
      <h2>Packaging</h2>
      <p>All cards are carefully packaged with protective sleeves, top loaders, and bubble wrap to ensure safe delivery.</p>
      <h2>Insurance</h2>
      <p>All shipments are fully insured. In case of damage or loss, please contact us within 48 hours of delivery.</p>
    </div>
  </div>
</BaseLayout>
