---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout locale="en" title="Terms of Service">
  <div class="container policy-page">
    <a href="/" class="link-back" style="display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1.5rem;font-size:0.875rem">← Back to Home</a>
    <h1>Terms of Service</h1>
    <p class="policy-updated">Last updated: March 2025</p>
    <div class="policy-content">
      <h2>Acceptance of Terms</h2>
      <p>By using PokéStop MTL, you agree to these terms. If you do not agree, please do not use our services.</p>
      <h2>Products and Pricing</h2>
      <p>All prices are in Canadian dollars. We reserve the right to modify prices at any time. Product availability is subject to change without notice.</p>
      <h2>Orders and Payment</h2>
      <p>Orders are confirmed upon payment. We accept major credit cards via Stripe. All transactions are secure and encrypted.</p>
      <h2>Returns and Refunds</h2>
      <p>Returns accepted within 14 days for items in original condition. Mystery packs and opened items are final sale. Contact us to initiate a return.</p>
      <h2>Limitation of Liability</h2>
      <p>PokéStop MTL is not liable for indirect, incidental, or consequential damages arising from the use of our products or services.</p>
    </div>
  </div>
</BaseLayout>
